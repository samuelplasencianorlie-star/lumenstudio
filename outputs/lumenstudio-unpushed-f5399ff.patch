+  .services-grid,
+  .process-grid {
+    border: 0;
+    background: transparent;
+  }
+
+  .ai-reels-grid {
+    grid-template-columns: 1fr;
+    width: min(360px, 100%);
+  }
+
+  .ai-reel,
+  .ai-reel:nth-child(1),
+  .ai-reel:nth-child(2),
+  .ai-reel:nth-child(3) {
+    grid-column: auto;
+    transform: none;
+  }
+
+  .service-card,
+  .process-step {
+    min-height: 260px;
+    border: 1px solid rgba(255, 255, 255, 0.08);
+  }
+
+  .social-showcase {
+    min-height: auto;
+    grid-template-columns: 1fr;
+    grid-template-rows: auto;
+  }
+
+  .reel-frame,
+  .reel-frame--secondary {
+    min-height: 420px;
+  }
+
+  .reel-frame--primary,
+  .image-slot--wide {
+    grid-column: auto;
+    grid-row: auto;
+  }
+
+  .image-slot--square {
+    display: flex;
+  }
+
+  .audit-shell {
+    padding: 2rem 1.15rem;
+  }
+
+  .cta-row {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .audit-cta,
+  .secondary-contact {
+    width: 100%;
+  }
+}
+
+@media (max-width: 460px) {
+  .ai-reels-grid {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  html {
+    scroll-behavior: auto;
+  }
+
+  .lumen-hero__cta,
+  .lumen-hero__object,
+  .lumen-hero__morph-veil,
+  .lumen-hero__stage,
+  .lumen-hero__copy {
+    transition: none;
+  }
+}
