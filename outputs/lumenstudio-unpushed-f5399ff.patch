--- /dev/null
+++ b/app/globals.css
@@ -0,0 +1,2034 @@
+@import "tailwindcss";
+
+:root {
+  color-scheme: dark;
+  background: #020306;
+  --lumen-blue: #1f6dff;
+  --lumen-cyan: #7dd9ff;
+  --lumen-white: #f7fbff;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  min-height: 100%;
+  background: #020306;
+  scroll-behavior: smooth;
+}
+
+body {
+  min-height: 100%;
+  margin: 0;
+  background: #020306;
+  color: var(--lumen-white);
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+  overflow-x: hidden;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+main {
+  min-height: 100vh;
+  background:
+    radial-gradient(circle at 50% 42%, rgba(35, 105, 255, 0.12), transparent 34%),
+    linear-gradient(180deg, #020306 0%, #010103 100%);
+}
+
+.site-header {
+  position: fixed;
+  top: 0;
+  left: 0;
+  z-index: 20;
+  display: grid;
+  width: 100%;
+  grid-template-columns: 1fr auto 1fr;
+  align-items: center;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 3vw, 2rem);
+  background: linear-gradient(180deg, rgba(2, 3, 6, 0.82), rgba(2, 3, 6, 0.38), transparent);
+  backdrop-filter: blur(18px);
+}
+
+.site-logo {
+  justify-self: start;
+  color: #f7fbff;
+  font-size: 0.88rem;
+  font-weight: 760;
+  letter-spacing: 0;
+}
+
+.site-nav {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  gap: clamp(1rem, 2.5vw, 2.2rem);
+}
+
+.site-nav a,
+.header-whatsapp,
+.language-switcher button {
+  color: rgba(247, 251, 255, 0.72);
+  font: inherit;
+  font-size: 0.9rem;
+  font-weight: 620;
+  letter-spacing: 0;
+}
+
+.site-nav a {
+  transition: color 180ms ease;
+}
+
+.site-nav a:hover {
+  color: #ffffff;
+}
+
+.site-actions {
+  display: flex;
+  align-items: center;
+  justify-content: flex-end;
+  gap: 0.75rem;
+}
+
+.language-switcher {
+  display: inline-flex;
+  align-items: center;
+  padding: 0.18rem;
+  border: 1px solid rgba(255, 255, 255, 0.12);
+  border-radius: 999px;
+  background: rgba(255, 255, 255, 0.05);
+}
+
+.language-switcher button {
+  min-width: 2.55rem;
+  min-height: 2rem;
+  border: 0;
+  border-radius: 999px;
+  background: transparent;
+  cursor: pointer;
+}
+
+.language-switcher button.is-active {
+  background: rgba(31, 109, 255, 0.92);
+  color: #ffffff;
+  box-shadow: 0 0 24px rgba(31, 109, 255, 0.34);
+}
+
+.header-whatsapp {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 2.35rem;
+  padding: 0 0.9rem;
+  border: 1px solid rgba(125, 217, 255, 0.24);
+  border-radius: 999px;
+  background: rgba(31, 109, 255, 0.12);
+  color: #ffffff;
+}
+
+.lumen-hero {
+  position: relative;
+  min-height: 250svh;
+  isolation: isolate;
+  background:
+    radial-gradient(circle at 50% 36%, rgba(28, 96, 255, 0.18), transparent 24%),
+    radial-gradient(circle at 50% 68%, rgba(125, 217, 255, 0.08), transparent 28%),
+    #020306;
+}
+
+.lumen-hero::before {
+  position: absolute;
+  inset: 0;
+  z-index: -2;
+  content: "";
+  background:
+    radial-gradient(circle at 50% 50%, transparent 0 44%, rgba(2, 3, 6, 0.42) 68%),
+    linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 18% 82%, rgba(255, 255, 255, 0.018));
+  pointer-events: none;
+}
+
+.lumen-hero::after {
+  position: absolute;
+  inset: auto 0 0;
+  height: 34vh;
+  z-index: -1;
+  content: "";
+  background: linear-gradient(180deg, transparent, #020306 72%);
+  pointer-events: none;
+}
+
+.lumen-hero__sticky {
+  position: sticky;
+  top: 0;
+  display: grid;
+  min-height: 100svh;
+  overflow: hidden;
+  padding: clamp(1.25rem, 3vw, 2.75rem);
+  place-items: center;
+}
+
+.lumen-hero__stage {
+  position: absolute;
+  inset: 0;
+  pointer-events: none;
+  perspective: 1100px;
+}
+
+.lumen-hero__object-field {
+  position: absolute;
+  top: clamp(8.5rem, 29vh, 17rem);
+  left: 50%;
+  width: min(72vw, 840px);
+  aspect-ratio: 16 / 9;
+  transform: translate3d(-50%, -50%, 0);
+  pointer-events: none;
+  perspective: 1100px;
+}
+
+.lumen-hero__object-field::before {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  width: min(72vw, 900px);
+  aspect-ratio: 1;
+  border-radius: 999px;
+  content: "";
+  background:
+    radial-gradient(circle, rgba(60, 137, 255, calc(0.18 + var(--lumen-pulse) * 0.22)), transparent 58%),
+    radial-gradient(circle, rgba(125, 217, 255, calc(var(--lumen-pulse) * 0.13)), transparent 46%);
+  filter: blur(64px);
+  opacity: 0.74;
+  transform: translate3d(-50%, -50%, 0) scale(calc(0.82 + var(--lumen-pulse) * 0.2));
+}
+
+.lumen-hero__aura {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  width: min(54vw, 660px);
+  aspect-ratio: 1;
+  border-radius: 999px;
+  mix-blend-mode: screen;
+  filter: blur(42px);
+  will-change: opacity, transform;
+}
+
+.lumen-hero__aura--orb {
+  background: radial-gradient(circle, rgba(31, 109, 255, 0.3), transparent 62%);
+  opacity: calc(var(--orb-opacity) * 0.75);
+  transform: translate3d(-54%, -51%, 0) scale(0.92);
+}
+
+.lumen-hero__aura--ribbon {
+  background: radial-gradient(ellipse, rgba(125, 217, 255, 0.36), transparent 64%);
+  opacity: calc(var(--ribbon-opacity) * 0.82);
+  transform: translate3d(-45%, -52%, 0) scale(1.12) rotate(-18deg);
+}
+
+.lumen-hero__morph-veil {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  width: min(38vw, 460px);
+  aspect-ratio: 1.18;
+  border-radius: 999px;
+  background:
+    linear-gradient(108deg, transparent 10%, rgba(125, 217, 255, 0.58), rgba(31, 109, 255, 0.2) 55%, transparent 82%),
+    radial-gradient(circle at 50% 48%, rgba(255, 255, 255, 0.2), transparent 42%);
+  filter: blur(16px);
+  mix-blend-mode: screen;
+  mask-image: linear-gradient(104deg, transparent 0%, #000 28%, #000 64%, transparent 100%);
+  pointer-events: none;
+  will-change: opacity, transform;
+}
+
+.lumen-hero__energy-ring,
+.lumen-hero__energy-core,
+.lumen-hero__morph-canvas {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  pointer-events: none;
+}
+
+.lumen-hero__energy-ring {
+  width: min(44vw, 520px);
+  aspect-ratio: 1.8;
+  border: 1px solid rgba(125, 217, 255, 0.34);
+  border-radius: 999px;
+  background:
+    linear-gradient(90deg, transparent, rgba(125, 217, 255, 0.2), transparent),
+    radial-gradient(ellipse at center, rgba(31, 109, 255, 0.28), transparent 68%);
+  box-shadow:
+    0 0 28px rgba(31, 109, 255, 0.34),
+    0 0 72px rgba(125, 217, 255, 0.12);
+  filter: blur(1px);
+  mix-blend-mode: screen;
+  will-change: opacity, transform;
+}
+
+.lumen-hero__energy-core {
+  width: min(34vw, 400px);
+  aspect-ratio: 2.8;
+  border-radius: 999px;
+  background:
+    linear-gradient(90deg, transparent 2%, rgba(125, 217, 255, 0.72), rgba(31, 109, 255, 0.32), transparent 96%),
+    radial-gradient(ellipse, rgba(255, 255, 255, 0.16), transparent 56%);
+  filter: blur(12px);
+  mix-blend-mode: screen;
+  will-change: opacity, transform;
+}
+
+.lumen-hero__morph-canvas {
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  opacity: 0;
+  transform: none;
+  transition: opacity 240ms ease;
+  filter: saturate(1.12) contrast(1.03);
+  will-change: opacity;
+}
+
+.lumen-hero__object-field--canvas-ready .lumen-hero__morph-canvas {
+  opacity: 1;
+}
+
+.lumen-hero__object-field--canvas-ready .lumen-hero__object {
+  opacity: 0 !important;
+}
+
+.lumen-hero__object {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  width: min(46vw, 590px);
+  max-height: 48svh;
+  object-fit: contain;
+  transform-origin: center;
+  user-select: none;
+  will-change: opacity, filter, transform, mask-image;
+  backface-visibility: hidden;
+}
+
+.lumen-hero__object--orb {
+  width: min(42vw, 530px);
+}
+
+.lumen-hero__object--ribbon {
+  width: min(50vw, 640px);
+}
+
+.lumen-hero__copy {
+  position: relative;
+  z-index: 2;
+  align-self: end;
+  width: min(760px, 100%);
+  margin-inline: auto;
+  padding-block: 0 clamp(2rem, 7vh, 4.8rem);
+  text-align: center;
+  text-wrap: balance;
+  transform: translate3d(0, calc(var(--lumen-progress) * -14px), 0);
+}
+
+.lumen-hero__copy h1 {
+  max-width: 760px;
+  margin: 0 auto;
+  color: #f7fbff;
+  font-size: clamp(2.55rem, 4.35vw, 4.45rem);
+  font-weight: 600;
+  letter-spacing: 0;
+  line-height: 1;
+}
+
+.lumen-hero__subheadline {
+  max-width: 620px;
+  margin: 1.1rem auto 0;
+  color: rgba(235, 244, 255, 0.74);
+  font-size: clamp(1rem, 1.5vw, 1.22rem);
+  line-height: 1.58;
+}
+
+.lumen-hero__cta {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 48px;
+  margin-top: 1.55rem;
+  padding: 0 1.25rem;
+  border: 1px solid rgba(125, 217, 255, 0.3);
+  border-radius: 999px;
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.05)),
+    rgba(31, 109, 255, 0.15);
+  box-shadow:
+    0 0 0 1px rgba(255, 255, 255, 0.08) inset,
+    0 18px 62px rgba(31, 109, 255, 0.22);
+  color: #ffffff;
+  font-size: 0.95rem;
+  font-weight: 650;
+  letter-spacing: 0;
+  transition:
+    border-color 180ms ease,
+    box-shadow 180ms ease,
+    transform 180ms ease,
+    background 180ms ease;
+}
+
+.lumen-hero__cta:hover {
+  border-color: rgba(125, 217, 255, 0.62);
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.07)),
+    rgba(31, 109, 255, 0.22);
+  box-shadow:
+    0 0 0 1px rgba(255, 255, 255, 0.13) inset,
+    0 22px 76px rgba(31, 109, 255, 0.3);
+  transform: translateY(-1px);
+}
+
+.lumen-hero__cta:focus-visible {
+  outline: 2px solid rgba(125, 217, 255, 0.9);
+  outline-offset: 4px;
+}
+
+.lumen-hero__actions {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  justify-content: center;
+  gap: 0.85rem;
+  margin-top: 1.55rem;
+}
+
+.lumen-hero__actions .lumen-hero__cta {
+  margin-top: 0;
+}
+
+.lumen-hero__secondary-cta {
+  display: inline-flex;
+  min-height: 48px;
+  align-items: center;
+  justify-content: center;
+  padding: 0 1.2rem;
+  border: 1px solid rgba(255, 255, 255, 0.14);
+  border-radius: 999px;
+  background: rgba(255, 255, 255, 0.04);
+  color: rgba(247, 251, 255, 0.86);
+  font-size: 0.95rem;
+  font-weight: 650;
+  letter-spacing: 0;
+  transition:
+    border-color 180ms ease,
+    background 180ms ease,
+    transform 180ms ease;
+}
+
+.lumen-hero__secondary-cta:hover {
+  border-color: rgba(125, 217, 255, 0.42);
+  background: rgba(255, 255, 255, 0.07);
+  transform: translateY(-1px);
+}
+
+@media (max-width: 820px) {
+  main {
+    min-height: 100svh;
+  }
+
+  .lumen-hero,
+  .lumen-hero--static {
+    min-height: 100svh;
+  }
+
+  .lumen-hero__sticky {
+    position: relative;
+    min-height: 100svh;
+    padding: 1rem;
+  }
+
+  .lumen-hero__stage {
+    transform: none;
+  }
+
+  .lumen-hero__object-field {
+    top: clamp(7rem, 28vh, 13rem);
+    width: min(112vw, 600px);
+  }
+
+  .lumen-hero__object-field::before {
+    width: 118vw;
+    filter: blur(48px);
+  }
+
+  .lumen-hero__aura {
+    width: 92vw;
+  }
+
+  .lumen-hero__morph-veil {
+    width: 86vw;
+    filter: blur(20px);
+  }
+
+  .lumen-hero__object,
+  .lumen-hero__object--orb,
+  .lumen-hero__object--ribbon {
+    width: min(94vw, 520px);
+    max-height: 48svh;
+  }
+
+  .lumen-hero__copy {
+    padding-bottom: max(1.35rem, env(safe-area-inset-bottom));
+  }
+
+  .lumen-hero__copy h1 {
+    font-size: clamp(2.28rem, 12vw, 3.85rem);
+    line-height: 0.98;
+  }
+
+  .lumen-hero__subheadline {
+    max-width: 24rem;
+    font-size: 1rem;
+  }
+}
+
+@media (max-width: 440px) {
+  .lumen-hero__stage {
+    transform: none;
+  }
+
+  .lumen-hero__object-field {
+    top: clamp(6.5rem, 25vh, 10rem);
+    width: 118vw;
+  }
+
+  .lumen-hero__object,
+  .lumen-hero__object--orb,
+  .lumen-hero__object--ribbon {
+    width: 108vw;
+    max-height: 48svh;
+  }
+
+  .lumen-hero__subheadline {
+    margin-top: 0.95rem;
+    line-height: 1.48;
+  }
+
+  .lumen-hero__cta {
+    width: min(100%, 18rem);
+  }
+
+  .lumen-hero__actions {
+    width: min(100%, 19rem);
+    margin-inline: auto;
+  }
+
+  .lumen-hero__secondary-cta {
+    width: 100%;
+  }
+}
+
+.homepage-section {
+  position: relative;
+  overflow: hidden;
+  padding: clamp(6rem, 10vw, 10rem) clamp(1.25rem, 4vw, 4rem);
+  background: #020306;
+}
+
+.section-shell {
+  width: min(1180px, 100%);
+  margin: 0 auto;
+}
+
+.section-heading {
+  width: min(760px, 100%);
+  margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
+}
+
+.section-heading--compact {
+  width: min(700px, 100%);
+}
+
+.section-kicker {
+  margin: 0 0 1rem;
+  color: rgba(125, 217, 255, 0.82);
+  font-size: 0.78rem;
+  font-weight: 700;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+.section-heading h2,
+.social-copy h2,
+.audit-shell h2 {
+  margin: 0;
+  color: #f8fbff;
+  font-size: clamp(2.35rem, 4.8vw, 5rem);
+  font-weight: 600;
+  letter-spacing: 0;
+  line-height: 1;
+  text-wrap: balance;
+}
+
+.section-heading p,
+.social-copy p,
+.audit-shell p {
+  max-width: 650px;
+  margin: 1.2rem 0 0;
+  color: rgba(235, 244, 255, 0.68);
+  font-size: clamp(1rem, 1.45vw, 1.18rem);
+  line-height: 1.65;
+}
+
+.services-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 1px;
+  border: 1px solid rgba(255, 255, 255, 0.08);
+  background: rgba(255, 255, 255, 0.08);
+}
+
+.services-grid--complete {
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+}
+
+.service-card {
+  display: flex;
+  min-height: 420px;
+  flex-direction: column;
+  justify-content: space-between;
+  padding: clamp(1.35rem, 2.4vw, 2.25rem);
+  border-radius: 0;
+  background:
+    radial-gradient(circle at 50% 0%, rgba(31, 109, 255, 0.14), transparent 38%),
+    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.018)),
+    #06070a;
+}
+
+.service-card:first-child {
+  border-radius: 8px 0 0 8px;
+}
+
+.service-card:last-child {
+  border-radius: 0 8px 8px 0;
+}
+
+.service-card__label,
+.service-card span {
+  color: rgba(125, 217, 255, 0.74);
+  font-size: 0.78rem;
+  font-weight: 700;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+.service-card h3 {
+  margin: 5.5rem 0 1rem;
+  color: #f7fbff;
+  font-size: clamp(1.75rem, 2.8vw, 2.65rem);
+  font-weight: 600;
+  letter-spacing: 0;
+  line-height: 1.02;
+}
+
+.homepage-section--ai-reels {
+  background:
+    radial-gradient(circle at 50% 24%, rgba(31, 109, 255, 0.16), transparent 32%),
+    linear-gradient(180deg, #020306, #030407);
+}
+
+.section-heading--wide {
+  width: min(850px, 100%);
+}
+
+.ai-reels-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: clamp(1.6rem, 3vw, 3rem);
+  align-items: center;
+}
+
+.ai-reel {
+  position: relative;
+  min-width: 0;
+  outline: none;
+  cursor: pointer;
+}
+
+.ai-reel__screen {
+  position: relative;
+  overflow: hidden;
+  aspect-ratio: 9 / 16;
+  border: 1px solid rgba(255, 255, 255, 0.1);
+  border-radius: 8px;
+  background:
+    radial-gradient(circle at 50% 18%, rgba(125, 217, 255, 0.22), transparent 28%),
+    linear-gradient(160deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02)),
+    #07080b;
+  box-shadow:
+    0 30px 100px rgba(0, 0, 0, 0.42),
+    0 0 0 1px rgba(255, 255, 255, 0.035) inset;
+  transition:
+    border-color 180ms ease,
+    box-shadow 180ms ease,
+    transform 220ms ease,
+    filter 220ms ease;
+}
+
+.ai-reel__screen::before {
+  position: absolute;
+  inset: 0;
+  content: "";
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 20%),
+    radial-gradient(circle at 50% 50%, rgba(31, 109, 255, 0.2), transparent 58%);
+}
+
+.ai-reel__screen::after {
+  position: absolute;
+  inset: auto 12% 1rem;
+  height: 3px;
+  border-radius: 999px;
+  content: "";
+  background: rgba(255, 255, 255, 0.2);
+}
+
+.ai-reel video {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+}
+
+.ai-reel__placeholder {
+  position: absolute;
+  inset: 0;
+  z-index: 1;
+  display: flex;
+  flex-direction: column;
+  justify-content: flex-end;
+  padding: 1rem;
+  background:
